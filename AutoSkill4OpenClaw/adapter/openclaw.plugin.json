{
  "id": "autoskill-openclaw-adapter",
  "name": "AutoSkill OpenClaw Adapter",
  "description": "AutoSkill adapter for OpenClaw embedded or sidecar skill evolution workflows.",
  "version": "0.1.0",
  "kind": "lifecycle",
  "main": "./index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:9100/v1",
        "description": "AutoSkill sidecar base URL."
      },
      "apiKey": {
        "type": "string",
        "default": "",
        "description": "Optional API key for the AutoSkill sidecar."
      },
      "userId": {
        "type": "string",
        "default": "",
        "description": "Optional fixed user id override."
      },
      "runtimeMode": {
        "type": "string",
        "enum": [
          "sidecar",
          "embedded"
        ],
        "default": "embedded",
        "description": "sidecar: send hooks to external AutoSkill service; embedded: run extraction/maintenance inside OpenClaw plugin runtime."
      },
      "embedded": {
        "type": "object",
        "description": "Embedded runtime options used when runtimeMode=embedded.",
        "properties": {
          "sessionArchiveDir": {
            "type": "string",
            "default": "",
            "description": "Session archive JSONL directory for embedded extraction."
          },
          "sessionMaxTurns": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000,
            "default": 20,
            "description": "Auto-close a long-lived embedded session after N turns when session_id never changes. 0 disables."
          },
          "liveExtractEveryTurns": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000,
            "default": 5,
            "description": "Run one live embedded extraction/maintenance pass every N turns for an active session without waiting for session end. 0 disables."
          },
          "skillBankDir": {
            "type": "string",
            "default": "",
            "description": "AutoSkill SkillBank root directory."
          },
          "openclawSkillsDir": {
            "type": "string",
            "default": "",
            "description": "OpenClaw standard local skills directory for mirror install."
          },
          "promptPackPath": {
            "type": "string",
            "default": "",
            "description": "Optional override path for the shared AutoSkill prompt pack."
          },
          "bm25TopK": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 8,
            "description": "Top-K candidate skills for BM25 similarity filtering before maintenance decision."
          },
          "modelInvocation": {
            "type": "object",
            "description": "Embedded model invocation fallback chain for extraction and maintenance.",
            "properties": {
              "modes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "openclaw-runtime",
                    "openclaw-runtime-subagent",
                    "openclaw-config-resolve",
                    "manual"
                  ]
                },
                "default": [
                  "openclaw-runtime",
                  "openclaw-runtime-subagent",
                  "openclaw-config-resolve",
                  "manual"
                ],
                "description": "Invocation fallback order. First successful mode is used."
              },
              "timeoutMs": {
                "type": "integer",
                "minimum": 1000,
                "maximum": 120000,
                "default": 20000,
                "description": "Per-request timeout for embedded model calls."
              },
              "retries": {
                "type": "integer",
                "minimum": 0,
                "maximum": 3,
                "default": 1,
                "description": "Retry count for HTTP-based embedded model calls."
              },
              "openclawHome": {
                "type": "string",
                "default": "",
                "description": "OpenClaw home path used by config-resolve mode."
              },
              "manualBaseUrl": {
                "type": "string",
                "default": "",
                "description": "Manual fallback base URL for OpenAI-compatible chat completions."
              },
              "manualApiKey": {
                "type": "string",
                "default": "",
                "description": "Manual fallback API key (optional if backend allows empty key)."
              },
              "manualModel": {
                "type": "string",
                "default": "",
                "description": "Manual fallback model id."
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "openclawSkillInstallMode": {
        "type": "string",
        "enum": [
          "openclaw_mirror",
          "store_only"
        ],
        "default": "openclaw_mirror",
        "description": "openclaw_mirror installs/mirrors skills to OpenClaw local directory; store_only keeps skills in AutoSkill store."
      },
      "skillScope": {
        "type": "string",
        "enum": [
          "all",
          "user",
          "library"
        ],
        "default": "all"
      },
      "skillRetrieval": {
        "type": "object",
        "description": "before_prompt_build retrieval and prompt augmentation settings.",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "topK": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 3
          },
          "maxChars": {
            "type": "integer",
            "minimum": 200,
            "maximum": 8000,
            "default": 1500
          },
          "minScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "default": 0.4
          },
          "injectionMode": {
            "type": "string",
            "enum": [
              "appendSystemContext",
              "prependSystemContext"
            ],
            "default": "appendSystemContext"
          }
        },
        "additionalProperties": false
      },
      "topK": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 3
      },
      "minScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1,
        "default": 0.4
      },
      "recallEnabled": {
        "type": "boolean",
        "default": false
      },
      "extractOnAgentEnd": {
        "type": "boolean",
        "default": true
      },
      "successOnly": {
        "type": "boolean",
        "default": true
      },
      "includeUserFeedback": {
        "type": "boolean",
        "default": true
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 500,
        "maximum": 30000,
        "default": 5000
      },
      "retries": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3,
        "default": 1
      },
      "logPayload": {
        "type": "boolean",
        "default": false
      },
      "maxInjectedChars": {
        "type": "integer",
        "minimum": 200,
        "maximum": 8000,
        "default": 1500,
        "description": "Legacy compatibility alias for skillRetrieval.maxChars."
      }
    },
    "additionalProperties": false
  }
}
